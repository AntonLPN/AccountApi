{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ApiSettings": {
    "ApiKeys": [
      "secretApiKey",
      "secretApiKey2"
    ]
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "Authority": "http://localhost:8080/realms/account-api",
        "MetadataAddress": "http://localhost:8080/realms/account-api/.well-known/openid-configuration",
        "ValidAudience": "account-api",
        "RequireHttpsMetadata": false
      }
    }
  },
  "KeycloakAdminClient": {
    "BaseUrl": "http://localhost:8080/",
    "Realm": "account-api",
    "ClientId": "account-api",
    "ClientSecret": "secret keycloak admin client"
  },
  "DbConfig": {
    "ConnectionString": "server=localhost;user=root;password=123456;database=AccountDb;"
  },
  "Messaging": {
    "UseRabbitMq": true,
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Port": 5672,
      "Username": "guest",
      "Password": "guest"
    },
    "Email": {
      "OwnerName": "your company name",
      "Email": "yourExample@email.com",
      "HostName": "smtp.gmail.com",
      "Password": "",
      "Port": 587
    }
  }
}
