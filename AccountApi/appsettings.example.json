{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ApiSettings": {
    "ApiKeys": [
      "secretApiKey",
      "secretApiKey2"
    ]
  },
  "JwtConfig": {
    "Issuer": "https://api.example.com",
    "Audience": "https://app.example.com",
    "SecretKey": "secretKeyForJwtTokenGeneration",
    "TokenTimeInDays": 1
  }
}
