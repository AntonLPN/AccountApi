{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ApiSettings": {
    "ApiKeys": [
      "secretApiKey",
      "secretApiKey2"
    ]
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "Authority": "http://localhost:8080/realms/account-realm",
        "MetadataAddress": "http://localhost:8080/realms/account-realm/.well-known/openid-configuration",
        "ValidAudience": "account-api",
        "RequireHttpsMetadata": false
      }
    }
  },
  "KeycloakAdminClient": {
    "BaseUrl": "http://localhost:8080/",
    "Realm": "account-api",
    "ClientId": "account-api",
    "ClientSecret": "secret keycloak admin client"
  },
  "DbConfig": {
    "ConnectionString": "server=localhost;user=root;password=123456;database=AccountDb;"
  }
}
